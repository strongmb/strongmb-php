{
    "name": "strongmb/strongmb-php",
    "description": "Official PHP SDK for the Strongmb API — simple, lightweight, and easy to integrate.",
    "type": "library",
    "license": "MIT",
    "keywords": ["strongmb", "api", "sdk", "airtime", "data", "nigeria", "strong mb", "bills", "payments", "mobile recharge", "utility payments", "gift cards", "vouchers", "strongmb api", "strongmb sdk", "php sdk", "php library", "strongmb api client", "strongmb api wrapper", "strongmb api integration", "strongmb api php", "strongmb api documentation", "strongmb api reference", "strongmb api examples"],
    "homepage": "https://developers.strongmb.ng",
    "authors": [
        {
            "name": "Strongmb",
            "email": "developers@strongmb.ng",
            "homepage": "https://strongmb.ng"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/http-client": "^6.4|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Strongmb\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Strongmb\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
